# Database - use one of these formats:
# Direct PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/travel_map"
# Prisma Postgres (local dev server via `npx prisma dev`):
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_map"

# NextAuth - generate a secret with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"
